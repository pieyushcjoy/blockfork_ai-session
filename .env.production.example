NODE_ENV=production
HOST=0.0.0.0
PORT=3100

# Server-side controls
MAX_CREDITS_USD=10
MAX_PER_SESSION_USD=1
MAX_REQUESTS_PER_SESSION_PER_MINUTE=20
SESSION_RATE_LIMIT_WINDOW_MS=60000

# Routing and admin
BLOCKFORK_DEFAULT_PROVIDER=openrouter
BLOCKFORK_DEFAULT_MODEL=managed
BLOCKFORK_ALLOW_MODEL_OVERRIDE=0
BLOCKFORK_ADMIN_SECRET=

# Upstream provider
OPENROUTER_API_KEY=
BLOCKFORK_LOCAL_BASE_URL=
BLOCKFORK_LOCAL_API_KEY=
BLOCKFORK_LOCAL_MODEL=
BLOCKFORK_LOCAL_STREAM_ESTABLISH_TIMEOUT_MS=20000
BLOCKFORK_LOCAL_STREAM_IDLE_BEFORE_HEADERS_TIMEOUT_MS=45000
BLOCKFORK_LOCAL_STREAM_IDLE_AFTER_HEADERS_TIMEOUT_MS=30000
BLOCKFORK_LOCAL_NON_STREAM_TIMEOUT_MS=30000
BLOCKFORK_LOCAL_ENABLE_NON_STREAM_RETRY=1
BLOCKFORK_LOCAL_PROFILE_ENABLE=1
BLOCKFORK_LOCAL_PROFILE_MAX_MESSAGES=48
BLOCKFORK_LOCAL_WARMUP_ENABLE=0
BLOCKFORK_LOCAL_WARMUP_INTERVAL_MS=90000
BLOCKFORK_LOCAL_WARMUP_TIMEOUT_MS=12000
BLOCKFORK_PRIMARY_NON_STREAM_TIMEOUT_MS=5000
BLOCKFORK_PRIMARY_STREAM_ESTABLISH_TIMEOUT_MS=5000
BLOCKFORK_ENABLE_FALLBACK=0
BLOCKFORK_FALLBACK_MODEL=
BLOCKFORK_FALLBACK_REQUIRE_FREE=1

# Non-production verification toggles
BLOCKFORK_FORCE_PRIMARY_429=0
BLOCKFORK_FORCE_PRIMARY_TIMEOUT=0
BLOCKFORK_ENABLE_TEST_UPSTREAM_KEY_OVERRIDE=0
