# BlockFork validation profile (non-production deterministic readiness drills)
# Usage:
#   cp .env.validation.example .env.validation
#   ENV_FILE=.env.validation npm run readiness:gate

HOST=127.0.0.1
PORT=3100
NODE_ENV=development

# Required runtime settings
BLOCKFORK_ADMIN_SECRET=replace_me
BLOCKFORK_DEFAULT_PROVIDER=openrouter
BLOCKFORK_DEFAULT_MODEL=managed
OPENROUTER_API_KEY=replace_me

# Local-first routing (optional; disable if local LM Studio unavailable)
BLOCKFORK_LOCAL_BASE_URL=http://127.0.0.1:1234/v1
BLOCKFORK_LOCAL_API_KEY=
BLOCKFORK_LOCAL_MODEL=google/gemma-4-e4b

# Enable fallback validation path
BLOCKFORK_ENABLE_FALLBACK=1
BLOCKFORK_FALLBACK_MODEL=managed
BLOCKFORK_FALLBACK_REQUIRE_FREE=0

# Deterministic failure drills for non-production validation
BLOCKFORK_FORCE_PRIMARY_429=1
BLOCKFORK_FORCE_PRIMARY_TIMEOUT=1
BLOCKFORK_ENABLE_TEST_UPSTREAM_KEY_OVERRIDE=1

BLOCKFORK_WORKSPACE_ALLOWED_ROOTS=/private/tmp
